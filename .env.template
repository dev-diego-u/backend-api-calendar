# ========================================
# CONFIGURACIÓN GENERAL DEL SERVIDOR
# ========================================

# Puerto en el que correrá el servidor
PORT=3000

# Entorno de ejecución (development, production, test)
NODE_ENV=development


# ========================================
# AUTENTICACIÓN - JWT
# ========================================

# Clave secreta para firmar los tokens JWT (¡cámbiala por una larga y segura!)
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# Tiempo de expiración del token
EXPIRATION_TIME=7d


# ========================================
# MONGODB ATLAS
# ========================================

# Credenciales de MongoDB Atlas
NAME_USER=your_mongodb_username
NAME_PASSWORD=your_mongodb_password
DB_NAME=your_database_name


# ========================================
# SEGURIDAD Y CORS
# ========================================

# Orígenes permitidos (CORS) - Separados por coma
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://tudominio.com

